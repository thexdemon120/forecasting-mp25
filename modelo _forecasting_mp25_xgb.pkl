    {
      "cell_type": "code",
      "source": [
        "import joblib\n",
        "from sklearn.metrics import mean_absolute_error, root_mean_squared_error\n",
        "import plotly.graph_objects as go\n",
        "import numpy as np\n",
        "\n",
        "# ==========================================\n",
        "# 1. INFERENCE CON DATOS NO VISTOS (TEST SET)\n",
        "# ==========================================\n",
        "print(\"=== Paso 7: Inferencia Final con Datos Fuera de la Muestra (Test 2025-2026) ===\")\n",
        "\n",
        "# Generar las predicciones predictivas definitivas usando XGBoost\n",
        "preds_test_xgb = model_xgb.predict(X_test)\n",
        "\n",
        "# Calcular métricas reales en producción simulada\n",
        "mae_test = mean_absolute_error(y_test, preds_test_xgb)\n",
        "rmse_test = root_mean_squared_error(y_test, preds_test_xgb)\n",
        "\n",
        "y_test_safe = np.where(y_test == 0, 1e-5, y_test)\n",
        "mape_test = np.mean(np.abs((y_test - preds_test_xgb) / y_test_safe)) * 100\n",
        "\n",
        "print(\"\\n DESEMPEÑO FINAL DEL MODELO (CONJUNTO DE PRUEBA):\")\n",
        "print(f\"   - MAE  : {mae_test:.2f} ug/m3\")\n",
        "print(f\"   - RMSE : {rmse_test:.2f} ug/m3\")\n",
        "print(f\"   - MAPE : {mape_test:.2f}%\")\n",
        "print(\"-\" * 55)\n",
        "\n",
        "# ==========================================\n",
        "# 2. GUARDAR EL MODELO PARA DESPLIEGUE (AVANCE 04)\n",
        "# ==========================================\n",
        "nombre_archivo_modelo = 'modelo_forecasting_mp25_xgb.pkl'\n",
        "print(f\"\\n Exportando el modelo entrenado a un archivo serializado...\")\n",
        "\n",
        "# Guardamos el modelo en formato comprimido para asegurar portabilidad\n",
        "joblib.dump(model_xgb, nombre_archivo_modelo, compress=3)\n",
        "\n",
        "print(f\" ¡Modelo guardado con éxito como '{nombre_archivo_modelo}'!\")\n",
        "print(\" Nota: Puedes descargar este archivo desde la barra lateral de Colab para usarlo en tu App/Demo final.\")\n",
        "\n",
        "# ==========================================\n",
        "# 3. VISUALIZACIÓN INTERACTIVA DE COMPROBACIÓN (TEST)\n",
        "# ==========================================\n",
        "# Graficamos las primeras 200 horas del conjunto de Test (Inicio de 2025)\n",
        "slice_test = 200\n",
        "\n",
        "fig_test = go.Figure()\n",
        "fig_test.add_trace(go.Scatter(\n",
        "    x=y_test.index[:slice_test], y=y_test.values[:slice_test],\n",
        "    mode='lines', name='Realidad (Test Real)', line=dict(color='black', width=2)\n",
        "))\n",
        "fig_test.add_trace(go.Scatter(\n",
        "    x=y_test.index[:slice_test], y=preds_test_xgb[:slice_test],\n",
        "    mode='lines', name='Inferencia XGBoost', line=dict(color='#e377c2', width=2, dash='dash')\n",
        "))\n",
        "\n",
        "fig_test.update_layout(\n",
        "    title='<b>Validación del Modelo Funcional en Producción (Datos No Vistos 2025)</b>',\n",
        "    xaxis=dict(title='Fecha y Hora', gridcolor='rgba(200, 200, 200, 0.2)'),\n",
        "    yaxis=dict(title='Concentración MP2.5 (ug/m3)', gridcolor='rgba(200, 200, 200, 0.2)'),\n",
        "    hovermode='x unified', plot_bgcolor='white', paper_bgcolor='white', height=500\n",
        ")\n",
        "fig_test.show()"
      ],
