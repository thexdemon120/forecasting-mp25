    {
      "cell_type": "code",
      "source": [
        "# 1. INSTALAR E IMPORTAR LIBRERÍAS DE PROGRESO VISUAL\n",
        "!pip install tqdm tqdm-joblib --quiet\n",
        "\n",
        "import joblib\n",
        "from tqdm.notebook import tqdm\n",
        "from tqdm_joblib import tqdm_joblib\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from xgboost import XGBRegressor\n",
        "from sklearn.metrics import mean_absolute_error, root_mean_squared_error\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# ==========================================\n",
        "# PASO 5: ENTRENAMIENTO DE MODELOS CON BARRAS DE PROGRESO\n",
        "# ==========================================\n",
        "print(\"=== Paso 5: Entrenando Modelos de Machine Learning ===\")\n",
        "\n",
        "# --- 1. RANDOM FOREST CON BARRA DE PROGRESO ---\n",
        "print(\"\\n🌲 Entrenando Modelo 1: Random Forest Regressor (100 árboles)...\")\n",
        "# Usamos tqdm_joblib para interceptar los 100 estimadores (árboles) que se calculan en paralelo\n",
        "with tqdm_joblib(tqdm(desc=\"Progreso Random Forest\", total=100)):\n",
        "    model_rf = RandomForestRegressor(n_estimators=100, random_state=42, n_jobs=-1)\n",
        "    model_rf.fit(X_train, y_train)\n",
        "\n",
        "\n",
        "# --- 2. XGBOOST CON MONITOREO DE ITERACIONES ---\n",
        "print(\"\\n Entrenando Modelo 2: XGBoost Regressor (150 iteraciones)...\")\n",
        "model_xgb = XGBRegressor(n_estimators=150, learning_rate=0.05, max_depth=6, random_state=42, n_jobs=-1)\n",
        "\n",
        "# XGBoost nos permite usar un 'eval_set' para ver cómo aprende árbol por árbol en tiempo real\n",
        "model_xgb.fit(\n",
        "    X_train, y_train,\n",
        "    eval_set=[(X_val, y_val)],\n",
        "    verbose=15 # Te mostrará el progreso en pantalla cada 15 árboles entrenados\n",
        ")\n",
        "\n",
        "print(\"\\n ¡Todos los modelos fueron entrenados con éxito!\\n\")\n",
        "\n",
        "# ==========================================\n",
        "# PASO 6: EVALUACIÓN Y COMPARACIÓN CON VAL_SET (2024)\n",
        "# ==========================================\n",
        "print(\"=== Paso 6: Evaluando Desempeño en Conjunto de Validación (2024) ===\")\n",
        "\n",
        "def calcular_metricas(y_real, y_pred, nombre_modelo):\n",
        "    mae = mean_absolute_error(y_real, y_pred)\n",
        "    rmse = root_mean_squared_error(y_real, y_pred)\n",
        "\n",
        "    y_real_safe = np.where(y_real == 0, 1e-5, y_real)\n",
        "    mape = np.mean(np.abs((y_real - y_pred) / y_real_safe)) * 100\n",
        "\n",
        "    print(f\" Métricas para {nombre_modelo}:\")\n",
        "    print(f\"   - MAE  : {mae:.2f} ug/m3\")\n",
        "    print(f\"   - RMSE : {rmse:.2f} ug/m3\")\n",
        "    print(f\"   - MAPE : {mape:.2f}%\")\n",
        "    print(\"-\" * 40)\n",
        "    return {\"MAE\": mae, \"RMSE\": rmse, \"MAPE\": mape}\n",
        "\n",
        "preds_rf_val  = model_rf.predict(X_val)\n",
        "preds_xgb_val = model_xgb.predict(X_val)\n",
        "\n",
        "metricas_rf  = calcular_metricas(y_val, preds_rf_val, \"Random Forest (Baseline)\")\n",
        "metricas_xgb = calcular_metricas(y_val, preds_xgb_val, \"XGBoost (Avanzado)\")\n",
        "\n",
        "# ==========================================\n",
        "# VISUALIZACIÓN GRÁFICA CRÍTICA\n",
        "# ==========================================\n",
        "slice_inicio = 4000\n",
        "slice_fin = 4336\n",
        "\n",
        "plt.figure(figsize=(15, 6))\n",
        "plt.plot(y_val.index[slice_inicio:slice_fin], y_val.values[slice_inicio:slice_fin], label='Realidad (SINCA)', color='black', linewidth=2)\n",
        "plt.plot(y_val.index[slice_inicio:slice_fin], preds_rf_val[slice_inicio:slice_fin], label='Predicción Random Forest', color='blue', linestyle='--', alpha=0.7)\n",
        "plt.plot(y_val.index[slice_inicio:slice_fin], preds_xgb_val[slice_inicio:slice_fin], label='Predicción XGBoost', color='red', linestyle='-.', alpha=0.8)\n",
        "\n",
        "plt.title('Comparación de Modelos en Periodo Crítico de Validación (Invierno 2024) - Temuco Las Encinas', fontsize=14)\n",
        "plt.xlabel('Fecha y Hora', fontsize=12)\n",
        "plt.ylabel('Concentración MP2.5 (ug/m3)', fontsize=12)\n",
        "plt.legend(fontsize=11)\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
