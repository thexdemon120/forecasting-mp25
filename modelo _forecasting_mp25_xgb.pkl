              "summary": "{\n  \"name\": \"display(X_train\",\n  \"rows\": 25,\n  \"fields\": [\n    {\n      \"column\": \"FECHA_HORA\",\n      \"properties\": {\n        \"dtype\": \"date\",\n        \"min\": \"2015-01-02 01:00:00\",\n        \"max\": \"2015-01-03 01:00:00\",\n        \"num_unique_values\": 25,\n        \"samples\": [\n          \"2015-01-02 09:00:00\",\n          \"2015-01-02 17:00:00\",\n          \"2015-01-02 01:00:00\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"HORA\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 24,\n        \"samples\": [\n          9,\n          17,\n          1\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"DIA_SEMANA\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 2,\n        \"samples\": [\n          5,\n          4\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"MES\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 1,\n        \"samples\": [\n          1\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"LAG_1\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 2.3359509127262643,\n        \"min\": 4.0,\n        \"max\": 12.0,\n        \"num_unique_values\": 7,\n        \"samples\": [\n          5.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"LAG_24\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 13.923361663046753,\n        \"min\": 4.0,\n        \"max\": 53.0,\n        \"num_unique_values\": 11,\n        \"samples\": [\n          21.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
