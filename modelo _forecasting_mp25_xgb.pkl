        "import plotly.graph_objects as go\n",
        "# continuación del anterior\n",
        "\n",
        "# 1. Definir el mismo rango de tiempo para la comparación (Invierno 2024)\n",
        "slice_inicio = 4000\n",
        "slice_fin = 4336\n",
        "\n",
        "# Crear las series de tiempo recortadas para el gráfico\n",
        "fechas_slice = y_val.index[slice_inicio:slice_fin]\n",
        "valores_reales = y_val.values[slice_inicio:slice_fin]\n",
        "valores_rf = preds_rf_val[slice_inicio:slice_fin]\n",
        "valores_xgb = preds_xgb_val[slice_inicio:slice_fin]\n",
        "\n",
        "# 2. Inicializar la figura interactiva de Plotly\n",
        "fig = go.Figure()\n",
        "\n",
        "# Agregar la línea de la Realidad (SINCA)\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=fechas_slice, y=valores_reales,\n",
        "    mode='lines',\n",
        "    name='Realidad (SINCA)',\n",
        "    line=dict(color='black', width=2),\n",
        "    hovertemplate='<b>Fecha:</b> %{x}<br><b>Real:</b> %{y:.2f} ug/m3<extra></extra>'\n",
        "))\n",
        "\n",
        "# Agregar la línea de Predicción Random Forest\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=fechas_slice, y=valores_rf,\n",
        "    mode='lines',\n",
        "    name='Predicción Random Forest',\n",
        "    line=dict(color='#1f77b4', width=1.5, dash='dash'),\n",
        "    hovertemplate='<b>Fecha:</b> %{x}<br><b>RF Pred:</b> %{y:.2f} ug/m3<extra></extra>'\n",
        "))\n",
        "\n",
        "# Agregar la línea de Predicción XGBoost\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=fechas_slice, y=valores_xgb,\n",
        "    mode='lines',\n",
        "    name='Predicción XGBoost',\n",
        "    line=dict(color='#d62728', width=2, dash='dot'),\n",
        "    hovertemplate='<b>Fecha:</b> %{x}<br><b>XGB Pred:</b> %{y:.2f} ug/m3<extra></extra>'\n",
        "))\n",
        "\n",
        "# 3. Personalizar el diseño del gráfico, añadir herramientas y el deslizador de rango (Range Slider)\n",
        "fig.update_layout(\n",
        "    title=dict(\n",
        "        text='<b>Análisis Interactivo de Predicciones en Periodo Crítico (Invierno 2024)</b><br><sup>Estación Las Encinas, Temuco - Use el mouse para hacer zoom</sup>',\n",
        "        x=0.5,\n",
        "        font=dict(size=16)\n",
        "    ),\n",
        "    xaxis=dict(\n",
        "        title='Fecha y Hora',\n",
        "        gridcolor='rgba(200, 200, 200, 0.2)',\n",
        "        rangeslider=dict(visible=True), # Agrega un mini-gráfico abajo para navegar el tiempo fácilmente\n",
        "        type='date'\n",
        "    ),\n",
        "    yaxis=dict(\n",
        "        title='Concentración MP2.5 (ug/m3)',\n",
        "        gridcolor='rgba(200, 200, 200, 0.2)'\n",
        "    ),\n",
        "    hovermode='x unified', # Muestra los tres valores simultáneamente al pararse en una fecha\n",
        "    plot_bgcolor='white',\n",
        "    paper_bgcolor='white',\n",
        "    legend=dict(\n",
        "        orientation='h',\n",
        "        yanchor='bottom',\n",
        "        y=1.02,\n",
        "        xanchor='right',\n",
        "        x=1\n",
        "    ),\n",
        "    height=650\n",
        ")\n",
        "\n",
        "# Mostrar el gráfico interactivo en Colab\n",
        "fig.show()"
      ],
