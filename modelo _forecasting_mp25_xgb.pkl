    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# PASO 3: VALIDACIÓN DE CONSISTENCIA CRONOLÓGICA\n",
        "# ==========================================\n",
        "print(\"=== Paso 3: Verificación de Límites Temporales ===\")\n",
        "print(f\"Train      : Desde {df_train.index.min()} hasta {df_train.index.max()} ({len(df_train)} registros)\")\n",
        "print(f\"Validation : Desde {df_val.index.min()} hasta {df_val.index.max()} ({len(df_val)} registros)\")\n",
        "print(f\"Test       : Desde {df_test.index.min()} hasta {df_test.index.max()} ({len(df_test)} registros)\\n\")\n",
        "\n",
        "# Aserciones de seguridad para asegurar aislamiento total\n",
        "assert df_train.index.max() < df_val.index.min(), \"¡Error! Hay solapamiento entre Train y Validation.\"\n",
        "assert df_val.index.max() < df_test.index.min(), \"¡Error! Hay solapamiento entre Validation y Test.\"\n",
        "print(\"[OK] Los conjuntos de datos están perfectamente aislados cronológicamente.\\n\")\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# PASO 4: PREPROCESAMIENTO SIN DATA LEAKAGE\n",
        "# ==========================================\n",
        "print(\"=== Paso 4: Iniciando Ingeniería de Features y Limpieza ===\")\n",
        "\n",
        "def transformar_y_limpiar_split(df, es_train=False):\n",
        "    \"\"\"\n",
        "    Aplica transformaciones de series de tiempo de forma aislada\n",
        "    para garantizar que no exista fuga de información (data leakage).\n",
        "    \"\"\"\n",
        "    # Copia profunda para no alterar los DataFrames originales\n",
        "    df_proced = df.copy()\n",
        "\n",
        "    # 1. Imputación temporal (Interpolación lineal basada en el tiempo)\n",
        "    # Rellena los baches horarios de forma determinista sin usar modelos iterativos cruzados\n",
        "    df_proced['MP2.5'] = df_proced['MP2.5'].interpolate(method='time')\n",
        "\n",
        "    # Si quedan nulos al extremo inicial/final que la interpolación no alcanzó, hacemos ffill/bfill\n",
        "    df_proced['MP2.5'] = df_proced['MP2.5'].ffill().bfill()\n",
        "\n",
        "    # 2. Extracción de variables de calendario (Derivadas del índice temporal)\n",
        "    df_proced['HORA'] = df_proced.index.hour\n",
        "    df_proced['DIA_SEMANA'] = df_proced.index.dayofweek\n",
        "    df_proced['MES'] = df_proced.index.month\n",
        "\n",
        "    # 3. Generación de Rezagos (Lags de la variable objetivo)\n",
        "    # Creamos retraso de 1 hora (t-1) y de 24 horas (t-24) para capturar el día anterior\n",
        "    df_proced['LAG_1'] = df_proced['MP2.5'].shift(1)\n",
        "    df_proced['LAG_24'] = df_proced['MP2.5'].shift(24)\n",
        "\n",
        "    # Como los descalces generan NaNs al inicio de la serie, los eliminamos con dropna\n",
        "    df_proced.dropna(inplace=True)\n",
        "\n",
        "    # Separación en Predictoras (X) y Objetivo (y)\n",
        "    columnas_predictoras = ['HORA', 'DIA_SEMANA', 'MES', 'LAG_1', 'LAG_24']\n",
        "    X = df_proced[columnas_predictoras]\n",
        "    y = df_proced['MP2.5']\n",
        "\n",
        "    return X, y\n",
        "\n",
        "# Procesar cada conjunto por separado para evitar Data Leakage\n",
        "X_train, y_train = transformar_y_limpiar_split(df_train, es_train=True)\n",
        "X_val, y_val     = transformar_y_limpiar_split(df_val)\n",
        "X_test, y_test   = transformar_y_limpiar_split(df_test)\n",
        "\n",
        "print(\"\\n ¡Ingeniería de variables finalizada con éxito!\")\n",
        "print(f\"Dimensiones finales -> X_train: {X_train.shape}, X_val: {X_val.shape}, X_test: {X_test.shape}\")\n",
        "print(\"\\nVista previa de las variables predictoras (X_train):\")\n",
        "display(X_train.head(25)) # Mostramos 25 filas para que se note cómo actúa el LAG_24"
      ],
      "metadata": {
